# Fund Registry local development defaults.
#
# Copy to .env only if your process manager loads env files. The app also runs
# with safe disabled payment/proof/anchor defaults when these are omitted.

FUND_REGISTRY_PUBLIC_BASE_URL=http://127.0.0.1:43134
FUND_REGISTRY_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
FUND_REGISTRY_HOST=127.0.0.1
FUND_REGISTRY_PORT=43134

FUND_REGISTRY_DB_PATH=data/fundregistry.db
FUND_REGISTRY_PHOTO_DIR=data/story-photos
FUND_REGISTRY_TRANSACTION_CACHE_DIR=data/tx-cache
FUND_REGISTRY_MESSAGES_PATH=data/messages.jsonl

# Production deployments should keep these disabled until Bitcoin Core wallets,
# proof support, and payment/anchor smoke tests are deliberately configured.
FUND_REGISTRY_PAYMENT_MODE=disabled
FUND_REGISTRY_PROOF_MODE=disabled
FUND_REGISTRY_ANCHOR_MODE=disabled

# Optional admin token for contact-message read-state mutations.
# FUND_REGISTRY_MESSAGES_ADMIN_TOKEN=

# Optional Bitcoin Core integration.
BITCOIN_BACKEND=local
BITCOIN_CLI_PATH=bitcoin-cli
# BITCOIN_CONF_PATH=
BITCOIN_WALLET_NAME=fund-registry-anchor
FUND_REGISTRY_PAYMENT_WALLET_NAME=fund-registry-payments
